    "next-mdx-remote": "latest",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "esbuild": "^0.28.1",
    "eslint": "latest",
    "eslint-config-next": "^15.0.0",
    "tailwindcss": "latest",
    "typescript": "latest",
    "wrangler": "^4.107.0"
